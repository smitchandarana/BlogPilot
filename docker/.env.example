# PostgreSQL
POSTGRES_PASSWORD=your-secure-password-here

# JWT signing secret (generate with: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=change-this-secret-in-production

# Stripe (optional — billing disabled if not set)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Admin account (created on first platform boot)
ADMIN_EMAIL=admin@phoenixsolution.in
ADMIN_PASSWORD=your-admin-password

# CORS (comma-separated origins allowed to access the API)
CORS_ORIGINS=https://app.phoenixsolution.in

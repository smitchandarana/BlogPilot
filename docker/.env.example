# Tailscale — exit node routing (all LinkedIn traffic exits through your home IP)
# Generate at: https://login.tailscale.com/admin/settings/keys
# Use an auth key with "Reusable" + "Ephemeral" disabled so the node persists
TAILSCALE_AUTHKEY=tskey-auth-xxxxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# PostgreSQL
POSTGRES_PASSWORD=your-secure-password-here

# JWT signing secret (generate with: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=change-this-secret-in-production

# Stripe (optional — billing disabled if not set)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Admin account (created on first platform boot)
ADMIN_EMAIL=admin@phoenixsolution.in
ADMIN_PASSWORD=your-admin-password

# Public-facing base URL (used in Stripe redirects, password reset links)
APP_BASE_URL=https://app.phoenixsolution.in

# Signup approval — set to "true" to require admin approval for new signups
REQUIRE_SIGNUP_APPROVAL=false

# Environment
BLOGPILOT_ENV=production

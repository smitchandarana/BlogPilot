{
  "manifest_version": 3,
  "name": "BlogPilot",
  "version": "2.0.0",
  "description": "AI-powered LinkedIn engagement assistant — generate comments, track leads, and grow your network.",

  "permissions": [
    "sidePanel",
    "storage",
    "unlimitedStorage",
    "alarms",
    "nativeMessaging",
    "activeTab",
    "notifications"
  ],

  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://api.groq.com/*",
    "https://api.openai.com/*",
    "https://api.anthropic.com/*",
    "https://openrouter.ai/*",
    "https://generativelanguage.googleapis.com/*"
  ],

  "background": {
    "service_worker": "background/service_worker.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content/linkedin_observer.js"],
      "run_at": "document_idle"
    }
  ],

  "side_panel": {
    "default_path": "sidepanel/index.html"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "BlogPilot"
  },

  "options_page": "sidepanel/index.html",

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "minimum_chrome_version": "116"
}
